# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# AI Service (for fallback when product not in hardcoded list)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Bot Configuration
BOT_USERNAME=@YourBotUsername
NODE_ENV=production

# Rate Limiting
RATE_LIMIT_WINDOW=3000
MAX_SEARCHES_PER_MINUTE=10

# Cache Settings (7 days = maximum free hits!)
CACHE_TTL_HOURS=168
MAX_CACHE_SIZE=1000

# Database
DB_PATH=./database/greenswitch.db

# Features
ENABLE_WEB_SEARCH=false
ENABLE_ANALYTICS=true

# Costs (Haiku model optimized for free tier)
AI_COST_PER_REQUEST=0.005
SEARCH_COST_PER_REQUEST=0.01